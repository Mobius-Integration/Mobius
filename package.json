{
  "name": "mobius-integration",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/assets/css/tailwind.css -o ./src/assets/css/tailwind.css",
    "watch:css": "tailwindcss -i ./src/assets/css/tailwind.css -o ./src/assets/css/tailwind.css --watch",
    "serve": "eleventy --serve",
    "start": "npm-run-all --parallel watch:css serve"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.0",         
    "tailwindcss": "^3.3.0",            
    "@tailwindcss/typography": "^0.5.9", 
    "@tailwindcss/forms": "^0.5.3",      
    "npm-run-all": "^4.1.5"              
  }
}

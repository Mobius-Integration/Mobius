---
layout: base
title: Contact
permalink: /contact/
---

<h1 class="text-3xl font-bold text-gray-900 mb-6">Get in Touch</h1>
<p class="text-gray-800 mb-8">Have questions or want to learn more about how AI can transform your business? Reach out to us below or schedule a free demo call.</p>

<div class="grid md:grid-cols-2 gap-8 items-start">
  <!-- Contact Form -->
  <div>
    <h2 class="text-2xl font-semibold text-gray-900 mb-4">Contact Us</h2>
    <form name="contactForm" method="POST" data-netlify="true" action="/thank-you-contact/">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1" for="name">Name</label>
        <input type="text" id="name" name="name" required class="w-full border border-gray-300 rounded px-3 py-2" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1" for="email">Email</label>
        <input type="email" id="email" name="email" required class="w-full border border-gray-300 rounded px-3 py-2" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1" for="message">Message</label>
        <textarea id="message" name="message" rows="4" required class="w-full border border-gray-300 rounded px-3 py-2"></textarea>
      </div>
      <button type="submit" class="bg-indigo-600 text-white font-medium px-5 py-2 rounded hover:bg-indigo-500">
        Send Message
      </button>
    </form>
  </div>

  <!-- Booking Section -->
  <div id="booking">
    <h2 class="text-2xl font-semibold text-gray-900 mb-4">Book a Demo/Consultation</h2>
    <p class="text-gray-800 mb-4">Choose a convenient time for a live demo or consultation with our team:</p>
    <!-- Example booking tool embed or link -->
    <div class="bg-gray-100 p-4 rounded">
      <!-- Embed code for Calendly or other scheduling tool goes here. Example: -->
      <p class="text-gray-600 italic">[Booking calendar widget will be embedded here]</p>
      <!-- For instance, if using Calendly: 
           <div class="calendly-inline-widget" data-url="https://calendly.com/your-calendly-link" style="min-width:320px;height:630px;"></div>
           <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript"></script>
      -->
      <!-- Or simply a link: -->
      <p class="mt-2">Prefer email? <a href="mailto:hello@mobiusintegration.com" class="text-indigo-600 underline">Email us</a> to schedule a call.</p>
    </div>
  </div>
</div>
